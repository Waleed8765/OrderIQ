PORT=5002
DATABASE_URL=""
DIRECT_URL=""

# Firebase Config (Admin SDK JSON stringified, or path to JSON file)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n\n-----END PRIVATE KEY-----\n"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# RAG + AI recommendations (Groq → local Ollama; see backend/rag/config.js)
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_LLM_MODEL="gemma3:1b"
#CLOUDINARY_URL=

# AI Recommendations (same LLM stack as RAG; no OpenRouter)
# Unset GROQ_API_KEY to use only Ollama for ranking.
AI_RECOMMENDATION_TIMEOUT_MS=8000
AI_RECOMMENDATION_CANDIDATE_POOL=12
AI_RECOMMENDATION_CACHE_TTL_MS=120000
# Max restaurants in the ranked list before pagination slices (default 60, max 150)
AI_RECOMMENDATION_MAX_ITEMS=60
